# ── Core ──────────────────────────────────────────────────────────
NODE_ENV=development
ENVIRONMENT=local                 # local | pilot | production
JWT_SECRET=change_me_to_a_long_random_string
SUPERADMIN_URL_PATH=change-me-to-something-unguessable

# ── Database (local docker-compose values shown; swap for Neon in Phase 1) ──
POSTGRES_USER=edtech
POSTGRES_PASSWORD=edtech_local_dev
POSTGRES_DB=edtech_platform
DATABASE_URL=postgresql+asyncpg://edtech:edtech_local_dev@postgres:5432/edtech_platform

# ── Cache (local docker-compose value shown; swap for Upstash REST URL in Phase 1) ──
REDIS_URL=redis://redis:6379/0

# ── Object storage — Cloudflare R2 ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=edtech-media

# ── AI — Anthropic (only key required to start building) ────────
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-haiku-4-5-20251001
AI_ESCALATION_MODEL=claude-sonnet-4-6

# ── AI — Embeddings (for pgvector semantic cache) ────────────────
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Voice — Sarvam AI (Marathi TTS/STT) ──────────────────────────
SARVAM_API_KEY=
# Alternative TTS if evaluating against Sarvam:
ELEVENLABS_API_KEY=

# ── Mobile OTP ────────────────────────────────────────────────────
OTP_PROVIDER=dev_mock              # dev_mock | firebase | msg91
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
MSG91_AUTH_KEY=

# ── Payments ──────────────────────────────────────────────────────
PAYMENT_PROVIDER=offline_mock      # offline_mock | razorpay_test | razorpay_live
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp (via BSP — AiSensy/Interakt/Gupshup/WATI) ───────────
WHATSAPP_BSP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Realtime gateway ──────────────────────────────────────────────
BACKEND_URL=http://backend:8000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
